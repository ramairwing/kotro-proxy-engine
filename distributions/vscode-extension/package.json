{
  "name": "kortolabs-proxy-engine",
  "displayName": "KortoLabs Proxy Engine",
  "description": "Transparent IDE sidecar for the Korto semantic caching LLM proxy.",
  "version": "0.2.6",
  "publisher": "kortosystems",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "keywords": [
    "ai",
    "proxy",
    "openai",
    "anthropic",
    "cache",
    "llm",
    "cursor",
    "streaming"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramairwing/kotro-proxy-engine.git",
    "directory": "distributions/vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Korto Proxy",
      "properties": {
        "kortosystems.profile": {
          "type": "string",
          "default": "custom",
          "enum": ["custom", "cursor", "copilot", "continue"],
          "enumDescriptions": [
            "Advanced (Manual toggle control)",
            "Cursor AI (Optimizes for Composer context streaming)",
            "GitHub Copilot (full_digest cache keys for strict autocompletion)",
            "Continue.dev (Standard semantic engine)"
          ],
          "description": "Pre-configured deployment profile for IDEs (KORTO_PROFILE)."
        },
        "kortosystems.listenAddr": {
          "type": "string",
          "default": ":8080",
          "description": "Proxy bind address for LLM traffic (KORTO_LISTEN_ADDR)."
        },
        "kortosystems.metricsAddr": {
          "type": "string",
          "default": "127.0.0.1:9090",
          "description": "Isolated telemetry socket for /metrics and /dashboard (KORTO_METRICS_ADDR)."
        },
        "kortosystems.upstreamUrl": {
          "type": "string",
          "default": "https://api.openai.com",
          "description": "Upstream provider base URL (KORTO_UPSTREAM_URL)."
        },
        "kortosystems.cacheDb": {
          "type": "string",
          "default": "",
          "description": "Cache database path. Empty uses extension global storage."
        },
        "kortosystems.enableCache": {
          "type": "boolean",
          "default": true
        },
        "kortosystems.enableRedaction": {
          "type": "boolean",
          "default": true
        },
        "kortosystems.enableCompression": {
          "type": "boolean",
          "default": true
        },
        "kortosystems.enableMetrics": {
          "type": "boolean",
          "default": true,
          "description": "Expose /metrics and /dashboard on the isolated telemetry socket (KORTO_ENABLE_METRICS)."
        }
      }
    },
    "commands": [
      {
        "command": "kortosystems.openDashboard",
        "title": "Korto: Open Dashboard",
        "category": "Korto"
      },
      {
        "command": "kortosystems.showProxyOutput",
        "title": "Korto: Show Proxy Logs",
        "category": "Korto"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "typescript": "^5.5.0"
  }
}
