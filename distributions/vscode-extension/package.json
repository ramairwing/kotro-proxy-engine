{
  "name": "kotro-proxy-engine",
  "displayName": "Kotro Proxy Engine",
  "description": "Local Kotro LLM proxy sidecar — downloads a SHA-256–verified binary and starts it on localhost. Agent routing is opt-in via Setup Wizard.",
  "version": "0.6.1",
  "publisher": "kotrolabs",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "keywords": [
    "ai",
    "proxy",
    "openai",
    "anthropic",
    "cache",
    "llm",
    "cursor",
    "streaming"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kotro-labs/kotro-proxy-engine.git",
    "directory": "distributions/vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Kotro Proxy",
      "properties": {
        "kotrolabs.profile": {
          "type": "string",
          "default": "custom",
          "enum": ["custom", "cursor", "copilot", "continue"],
          "enumDescriptions": [
            "Advanced (Manual toggle control)",
            "Cursor AI (Optimizes for Composer context streaming)",
            "GitHub Copilot (full_digest cache keys for strict autocompletion)",
            "Continue.dev (Standard semantic engine)"
          ],
          "description": "Pre-configured deployment profile for IDEs (KOTRO_PROFILE)."
        },
        "kotrolabs.listenAddr": {
          "type": "string",
          "default": ":8080",
          "description": "Proxy bind address for LLM traffic (KOTRO_LISTEN_ADDR)."
        },
        "kotrolabs.metricsAddr": {
          "type": "string",
          "default": "127.0.0.1:9090",
          "description": "Isolated telemetry socket for /metrics and /dashboard (KOTRO_METRICS_ADDR)."
        },
        "kotrolabs.upstreamUrl": {
          "type": "string",
          "default": "https://api.openai.com",
          "description": "Upstream provider base URL (KOTRO_UPSTREAM_URL)."
        },
        "kotrolabs.bridgeToken": {
          "type": "string",
          "default": "",
          "description": "When set (KOTRO_BRIDGE_TOKEN), LLM routes require this token. Generate with `uuidgen` or `openssl rand -hex 32`. Put the same value in Cursor’s OpenAI API key field when using a public tunnel. Leave empty for localhost-only clients."
        },
        "kotrolabs.upstreamApiKey": {
          "type": "string",
          "default": "",
          "description": "Provider API key injected upstream when bridgeToken is set (KOTRO_UPSTREAM_API_KEY). Do not put this in Cursor’s API key field when using bridge auth."
        },
        "kotrolabs.cacheDb": {
          "type": "string",
          "default": "",
          "description": "Cache database path. Empty uses extension global storage."
        },
        "kotrolabs.enableCache": {
          "type": "boolean",
          "default": true
        },
        "kotrolabs.enableRedaction": {
          "type": "boolean",
          "default": true
        },
        "kotrolabs.enableCompression": {
          "type": "boolean",
          "default": true
        },
        "kotrolabs.enableShrink": {
          "type": "boolean",
          "default": true
        },
        "kotrolabs.fallbackUrl": {
          "type": "string",
          "default": ""
        },
        "kotrolabs.fallbackModel": {
          "type": "string",
          "default": ""
        },
        "kotrolabs.enableMetrics": {
          "type": "boolean",
          "default": true,
          "description": "Expose /metrics and /dashboard on the isolated telemetry socket (KOTRO_ENABLE_METRICS)."
        }
      }
    },
    "commands": [
      {
        "command": "kotrolabs.openDashboard",
        "title": "Kotro: Open Dashboard",
        "category": "Kotro"
      },
      {
        "command": "kotro.statusBarMenu",
        "title": "Kotro: Status Menu",
        "category": "Kotro"
      },
      {
        "command": "kotrolabs.showProxyOutput",
        "title": "Kotro: Show Proxy Logs",
        "category": "Kotro"
      },
      {
        "command": "kotrolabs.verifyCache",
        "title": "Kotro: Verify Cache",
        "category": "Kotro"
      },
      {
        "command": "kotro.setupWizard",
        "title": "Kotro: Setup Wizard",
        "category": "Kotro"
      },
      {
        "command": "kotro.connectCursor",
        "title": "Kotro: Connect Cursor",
        "category": "Kotro"
      },
      {
        "command": "kotro.setupContinue",
        "title": "Kotro: Setup Continue.dev Config",
        "category": "Kotro"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --no-dependencies",
    "package:clean": "rm -rf out && npm run compile && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "typescript": "^5.5.0"
  }
}
